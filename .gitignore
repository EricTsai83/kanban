# =============================================================================
# Monorepo — pnpm workspace + Turborepo
# apps/web: Next.js
# apps/api: FastAPI (Python)
# =============================================================================

# ── Node / pnpm ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# Yarn (keep patches/plugins/releases/versions if used)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Turborepo ─────────────────────────────────────────────────────────────────
.turbo/

# ── Next.js (apps/web) ────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ── Python / FastAPI (apps/api) ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# pytest / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# mypy / ruff / pyright caches
.mypy_cache/
.ruff_cache/
.pyright/

# ── Build output ──────────────────────────────────────────────────────────────
build/
dist/

# ── Testing / coverage ────────────────────────────────────────────────────────
coverage/

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Environment files ─────────────────────────────────────────────────────────
.env*
!.env.example

# ── Misc ──────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
.vercel

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
