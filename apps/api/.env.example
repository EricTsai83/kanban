# =============================================================================
# apps/api — FastAPI environment variables
# Copy this file to .env and fill in the values.
# =============================================================================

# ── Database (NeonDB / PostgreSQL) ───────────────────────────────────────────

# Recommended for most uses (pooled via pgbouncer)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?channel_binding=require&sslmode=require

# For uses requiring a direct connection without pgbouncer
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require

# Individual connection parameters (alternative to DATABASE_URL)
PGHOST=HOST-pooler.REGION.aws.neon.tech
PGHOST_UNPOOLED=HOST.REGION.aws.neon.tech
PGUSER=USER
PGDATABASE=DBNAME
PGPASSWORD=PASSWORD

# ── Vercel Postgres / Prisma compatible aliases ───────────────────────────────
POSTGRES_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?channel_binding=require&sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?channel_binding=require&sslmode=require
POSTGRES_URL_NO_SSL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME
POSTGRES_PRISMA_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?channel_binding=require&connect_timeout=15&sslmode=require
POSTGRES_USER=USER
POSTGRES_HOST=HOST-pooler.REGION.aws.neon.tech
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DATABASE=DBNAME

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin allowed in production. In development, http://localhost:3000 is always allowed.
ALLOWED_ORIGIN=https://your-frontend-domain.com

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute path to the directory containing engineering-kanban-board.json.
# Defaults to the `data/` directory adjacent to main.py if left empty.
DATA_DIR=
