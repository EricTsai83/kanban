      "id": "item-001",
      "title": "Migrate authentication to OAuth 2.0",
      "description": "Replace our legacy session-based auth with OAuth 2.0 + PKCE flow. This will allow third-party integrations and improve security posture across all services.\n\nAcceptance criteria:\n- Support Google and GitHub as identity providers\n- Refresh token rotation enabled\n- Session invalidation on logout propagates to all devices",
      "assignee": "Sarah Chen",
      "priority": "high",
      "labels": ["security", "backend", "breaking-change"],
      "estimate": 13,
      "startDate": null,
      "dueDate": "2026-04-30T00:00:00.000Z",
